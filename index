  function isThisMonth(dateStr){
    const d = new Date(dateStr + 'T00:00:00');
    return d.getFullYear() === now.getFullYear() && d.getMonth() === now.getMonth();
  }

  function renderDashboard(){
    $('dashMonthLabel').textContent = now.toLocaleDateString('en-GB', { month:'long', year:'numeric' });

    const monthTrips = trips.filter(t=>isThisMonth(t.date));
    const work = monthTrips.filter(t=>t.type==='work').reduce((a,t)=>a+t.distance,0);
    const personal = monthTrips.filter(t=>t.type==='personal').reduce((a,t)=>a+t.distance,0);
    const total = work + personal;
    $('workTotal').innerHTML = work.toFixed(1) + ' <span>mi</span>';
    $('personalTotal').innerHTML = personal.toFixed(1) + ' <span>mi</span>';
    const workPct = total > 0 ? Math.round((work/total)*100) : 0;
    const personalPct = total > 0 ? 100 - workPct : 0;
    $('segWork').style.width = workPct + '%';
    $('segPersonal').style.width = personalPct + '%';
    $('workPct').textContent = workPct + '% work';
    $('personalPct').textContent = personalPct + '% personal';

    // This week (Mon-Sun) — clocked weekly
    const day = now.getDay();
    const diffToMonday = day === 0 ? -6 : 1 - day;
    const monday = new Date(now.getFullYear(), now.getMonth(), now.getDate() + diffToMonday);
    const sunday = new Date(monday.getFullYear(), monday.getMonth(), monday.getDate() + 6);
    const mondayStr = monday.getFullYear() + '-' + pad(monday.getMonth()+1) + '-' + pad(monday.getDate());
    const sundayStr = sunday.getFullYear() + '-' + pad(sunday.getMonth()+1) + '-' + pad(sunday.getDate());
    const weekHours = hoursEntries.filter(h=>h.date >= mondayStr && h.date <= sundayStr).reduce((a,h)=>a+h.hours,0);

    const weekPct = weeklyHours > 0 ? Math.min(100, (weekHours/weeklyHours)*100) : 0;
    $('weekBarFill').style.width = weekPct + '%';
    $('weekBarFill').classList.toggle('over', weekHours > weeklyHours);
    $('weekCaptionLeft').textContent = weekHours.toFixed(1) + ' hrs logged';
    $('weekCaptionRight').textContent = weeklyHours + ' hrs/week';

    const weekBanner = $('weekOvertimeBanner');
    if(weekHours > weeklyHours){
      const ot = weekHours - weeklyHours;
      weekBanner.className = 'overtime-banner over';
      weekBanner.textContent = 'Overtime this week: ' + ot.toFixed(1) + ' hrs';
    }else{
      const remaining = weeklyHours - weekHours;
      weekBanner.className = 'overtime-banner under';
      weekBanner.textContent = remaining <= 0 ? 'Weekly hours met exactly' : remaining.toFixed(1) + ' hrs to go this week';
    }

    // This month — paid monthly, still tracked against 160
    const monthHours = hoursEntries.filter(h=>isThisMonth(h.date)).reduce((a,h)=>a+h.hours,0);
    $('hoursTotal').innerHTML = monthHours.toFixed(1) + ' <span>hrs</span>';

    const pct = contractedHours > 0 ? Math.min(100, (monthHours/contractedHours)*100) : 0;
    $('hoursBarFill').style.width = pct + '%';
    $('hoursBarFill').classList.toggle('over', monthHours > contractedHours);
    $('hoursCaptionLeft').textContent = monthHours.toFixed(1) + ' hrs logged';
    $('hoursCaptionRight').textContent = contractedHours + ' hrs contracted';

    const banner = $('overtimeBanner');
    if(monthHours > contractedHours){
      const ot = monthHours - contractedHours;
      banner.className = 'overtime-banner over';
      banner.textContent = 'Overtime this month: ' + ot.toFixed(1) + ' hrs';
    }else{
      const remaining = contractedHours - monthHours;
      banner.className = 'overtime-banner under';
      banner.textContent = remaining <= 0 ? 'Contracted hours met exactly' : remaining.toFixed(1) + ' hrs to go to reach contracted hours';
    }

    // Away from home this month
    const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
    const monthEnd = new Date(now.getFullYear(), now.getMonth()+1, 0);
    let awayDays = 0;
    const jobsThisMonth = new Set();
    for(let d = new Date(monthStart); d <= monthEnd; d.setDate(d.getDate()+1)){
      const dateStr = d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate());
      const dj = jobsForDate(dateStr);
      if(dj.length > 0){ awayDays++; dj.forEach(j=>jobsThisMonth.add(j.id)); }
    }
    $('awayDaysTotal').innerHTML = awayDays + ' <span>days</span>';
    $('awayJobsTotal').textContent = jobsThisMonth.size;

    const todayJobs = jobsForDate(todayISO());
    const jobBanner = $('currentJobBanner');
    if(todayJobs.length > 0){
      const j = todayJobs[0];
      const actual = actualHoursForDate(todayISO());
      const over = j.expectedHours > 0 && actual > j.expectedHours;
      jobBanner.className = 'overtime-banner ' + (over ? 'over' : 'under');
      jobBanner.textContent = 'Currently away: ' + j.title + ' (until ' + j.endDate + ')' + (over ? ' \u2014 over expected hours today' : '');
      jobBanner.classList.remove('hidden');
    }else{
      jobBanner.classList.add('hidden');
    }
  }

  // ---------------- Reports / PDF export ----------------
  function monthKeyOf(dateStr){ return dateStr.slice(0,7); }
  function monthLabel(key){
    const [y,m] = key.split('-').map(Number);
    return new Date(y, m-1, 1).toLocaleDateString('en-GB', { month:'long', year:'numeric' });
  }
  function computeAvailableMonths(){
    const keys = new Set();
    trips.forEach(t=>keys.add(monthKeyOf(t.date)));
    hoursEntries.forEach(h=>keys.add(monthKeyOf(h.date)));
    keys.add(monthKeyOf(todayISO()));
    return Array.from(keys).sort().reverse();
  }
  function renderReportMonthOptions(){
    const sel = $('reportMonth');
    const current = sel.value;
    const months = computeAvailableMonths();
    sel.innerHTML = months.map(k=>'<option value="'+k+'">'+monthLabel(k)+'</option>').join('');
    if(months.includes(current)) sel.value = current;
  }

