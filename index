  $('toLoc').addEventListener('focus', ()=>{ activeAddressField = 'toLoc'; });

  function computeDistance(){
    if(mode === 'odometer'){
      const s = parseFloat($('startOdo').value);
      const e = parseFloat($('endOdo').value);
      if(!isNaN(s) && !isNaN(e) && e >= s) return e - s;
      return 0;
    }else if(mode === 'manual'){
      const d = parseFloat($('manualDistance').value);
      return !isNaN(d) && d >= 0 ? d : 0;
    }else{
      return addressDistance || 0;
    }
  }

  function setGaugeStatus(msg, isError){
    $('gaugeStatus').textContent = msg || '';
    $('gaugeStatus').style.color = isError ? 'var(--danger)' : 'var(--text-dim)';
  }

  function updateGauge(){
    currentDistance = computeDistance();
    $('gaugeValue').textContent = currentDistance.toFixed(1);
    const offset = currentDistance > 0 ? CIRC - (CIRC * 0.94) : CIRC;
    $('gaugeFill').style.strokeDashoffset = offset;
    $('gaugeFill').setAttribute('stroke', typeState === 'work' ? '#8b5cf6' : '#2dd4bf');
  }

  // ---------------- Address autocomplete ----------------
  function debounce(fn, delay){
    let t;
    return (...args)=>{ clearTimeout(t); t = setTimeout(()=>fn(...args), delay); };
  }

  async function fetchSuggestions(query){
    const url = 'https://nominatim.openstreetmap.org/search?format=json&addressdetails=0&limit=5&q=' + encodeURIComponent(query);
    const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
    if(!res.ok) return [];
    return await res.json();
  }

  function setupAutocomplete(inputId, boxId, onSelect){
    const input = $(inputId);
    const box = $(boxId);
    const runSearch = debounce(async ()=>{
      const q = input.value.trim();
      if(q.length < 3){ box.classList.remove('open'); box.innerHTML = ''; return; }
      let results = [];
      try{ results = await fetchSuggestions(q); }catch(e){ results = []; }
      if(!results.length){ box.classList.remove('open'); box.innerHTML = ''; return; }
      box.innerHTML = results.map((r,i)=>'<div class="ac-item" data-idx="' + i + '">' + escapeHtml(r.display_name) + '</div>').join('');
      box.classList.add('open');
      box.querySelectorAll('.ac-item').forEach(el=>{
        el.addEventListener('mousedown', (e)=>{
          e.preventDefault();
          const r = results[el.dataset.idx];
          input.value = r.display_name;
          onSelect({ lat: parseFloat(r.lat), lon: parseFloat(r.lon) });
          box.classList.remove('open');
          box.innerHTML = '';
          if(mode === 'address'){ addressDistance = 0; addressDuration = 0; hideRouteInfo(); setGaugeStatus(''); updateGauge(); }
        });
      });
    }, 400);
    input.addEventListener('input', ()=>{ onSelect(null); runSearch(); });
    input.addEventListener('blur', ()=>{ setTimeout(()=>box.classList.remove('open'), 150); });
  }
  setupAutocomplete('fromLoc', 'fromSuggestions', c=>{ fromCoord = c; });
  setupAutocomplete('toLoc', 'toSuggestions', c=>{ toCoord = c; });

  // ---------------- Address geocoding + routing ----------------
  async function geocode(query){
    const url = 'https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(query);
    const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
    if(!res.ok) throw new Error('geocode failed');
    const data = await res.json();
    if(!data || !data.length) throw new Error('Address not found: ' + query);
    return { lat: parseFloat(data[0].lat), lon: parseFloat(data[0].lon) };
  }

  async function routeInfo(a, b){
    const url = 'https://router.project-osrm.org/route/v1/driving/' + a.lon + ',' + a.lat + ';' + b.lon + ',' + b.lat + '?overview=false';
    const res = await fetch(url);
    if(!res.ok) throw new Error('routing failed');
    const data = await res.json();
    if(!data.routes || !data.routes.length) throw new Error('No route found');
    const r = data.routes[0];
    return { miles: r.distance * MI_PER_METER, minutes: r.duration / 60 };
  }

  function formatDuration(mins){
    const h = Math.floor(mins / 60);
    const m = Math.round(mins % 60);
    return h > 0 ? (h + 'h ' + m + 'm') : (m + 'm');
  }

  function showRouteInfo(){
    $('routeDuration').textContent = formatDuration(addressDuration);
    $('routeInfo').classList.remove('hidden');
    updateLeaveBy();
  }
  function hideRouteInfo(){
    $('routeInfo').classList.add('hidden');
    $('leaveByRow').style.display = 'none';
  }
  function updateLeaveBy(){
    const arrival = $('arrivalTime').value;
    if(!arrival || !addressDuration){ $('leaveByRow').style.display = 'none'; return; }
    const tripDateVal = $('tripDate').value || todayISO();
    const arrivalDate = new Date(tripDateVal + 'T' + arrival + ':00');
    const leaveDate = new Date(arrivalDate.getTime() - addressDuration * 60000);
    const hh = String(leaveDate.getHours()).padStart(2, '0');
    const mm = String(leaveDate.getMinutes()).padStart(2, '0');
    const dayLabel = leaveDate.toLocaleDateString('en-GB', { day:'2-digit', month:'short' });
    $('leaveByTime').textContent = hh + ':' + mm + ' (' + dayLabel + ')';
    $('leaveByRow').style.display = 'flex';
  }
  $('arrivalTime').addEventListener('change', updateLeaveBy);
  $('tripDate').addEventListener('change', updateLeaveBy);
  function autoSuggestWorkForDate(){
    if(editingTripId) return; // don't override an in-progress edit
    if(jobsForDate($('tripDate').value).length > 0 && typeState !== 'work'){
      typeState = 'work';
      $('typeToggle').dataset.state = 'work';
      $('labelWork').classList.add('on');
      $('labelPersonal').classList.remove('on');
      updateGauge();
    }
  }
  $('tripDate').addEventListener('change', autoSuggestWorkForDate);

  $('calcRouteBtn').addEventListener('click', async ()=>{
    const fromAddr = $('fromLoc').value.trim();
    const toAddr = $('toLoc').value.trim();
    if(!fromAddr || !toAddr){ setGaugeStatus('Enter both a From and To address first.', true); return; }
    $('calcRouteBtn').disabled = true;
    $('calcRouteBtn').textContent = (fromCoord && toCoord) ? 'Calculating route…' : 'Looking up addresses…';
    setGaugeStatus('');
    try{
      const fromGeo = fromCoord || await geocode(fromAddr);
      const toGeo = toCoord || await geocode(toAddr);
      $('calcRouteBtn').textContent = 'Calculating route…';
      const result = await routeInfo(fromGeo, toGeo);
      addressDistance = result.miles;
      addressDuration = result.minutes;
      updateGauge();
      showRouteInfo();
      setGaugeStatus('Route calculated ✓');
    }catch(err){
      addressDistance = 0;
      addressDuration = 0;
      updateGauge();
      hideRouteInfo();
      setGaugeStatus('Could not calculate that route — check the addresses, or switch to Manual / Odometer.', true);
    }finally{
      $('calcRouteBtn').disabled = false;
      $('calcRouteBtn').textContent = 'Calculate route';
    }
  });

  // ---------------- Recent addresses ----------------
  function computeRecentAddresses(){
    const seen = new Set();
    const list = [];
    trips.forEach(t=>{
      [t.to, t.from].forEach(addr=>{
        if(!addr) return;
        const key = addr.toLowerCase();
        if(!seen.has(key)){ seen.add(key); list.push(addr); }
      });
    });
    jobs.forEach(j=>{
      if(j.location){
        const key = j.location.toLowerCase();
        if(!seen.has(key)){ seen.add(key); list.push(j.location); }
      }
    });
    return list.slice(0, 8);
  }

  function renderRecentAddresses(){
    const box = $('recentAddressChips');
    const list = computeRecentAddresses();
    if(list.length === 0){ box.classList.add('hidden'); box.innerHTML = ''; return; }
    box.classList.remove('hidden');
    box.innerHTML = list.map((addr,i)=>'<div class="chip" data-idx="' + i + '">' + escapeHtml(addr) + '</div>').join('');
    box.querySelectorAll('.chip').forEach(chip=>{
      chip.addEventListener('click', ()=>{
        const addr = list[chip.dataset.idx];
        const field = $(activeAddressField);
        field.value = addr;
        field.dispatchEvent(new Event('input', { bubbles:true }));
      });
    });
  }

  // ---------------- GPS trip capture ----------------
  function getPosition(){
    return new Promise((resolve, reject)=>{
      if(!navigator.geolocation){ reject(new Error('Geolocation not supported')); return; }
      navigator.geolocation.getCurrentPosition(
        pos => resolve({ lat: pos.coords.latitude, lon: pos.coords.longitude }),
        err => reject(err),
        { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
      );
    });
  }

  async function reverseGeocode(coord){
    try{
      const url = 'https://nominatim.openstreetmap.org/reverse?format=json&lat=' + coord.lat + '&lon=' + coord.lon;
      const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
      if(!res.ok) throw new Error('reverse geocode failed');
      const data = await res.json();
      return data.display_name || (coord.lat.toFixed(4) + ', ' + coord.lon.toFixed(4));
    }catch(e){
      return coord.lat.toFixed(4) + ', ' + coord.lon.toFixed(4);
    }
  }

