    });
  });

  $('calPrev').addEventListener('click', ()=>{ calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCalendar(); });
  $('calNext').addEventListener('click', ()=>{ calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCalendar(); });
  $('yearPrev').addEventListener('click', ()=>{ calYear--; renderYearView(); });
  $('yearNext').addEventListener('click', ()=>{ calYear++; renderYearView(); });

  function pad(n){ return n < 10 ? '0'+n : ''+n; }
  function renderCalendarView(){
    if(calViewMode === 'year') renderYearView(); else renderCalendar();
  }

  function renderYearView(){
    $('calYearLabel').textContent = String(calYear);
    const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const stats = [];
    let maxMiles = 0;
    for(let m=0; m<12; m++){
      const key = calYear + '-' + pad(m+1);
      const mTrips = trips.filter(t=>monthKeyOf(t.date)===key);
      const work = mTrips.filter(t=>t.type==='work').reduce((a,t)=>a+t.distance,0);
      const personal = mTrips.filter(t=>t.type==='personal').reduce((a,t)=>a+t.distance,0);
      const hrs = hoursEntries.filter(h=>monthKeyOf(h.date)===key).reduce((a,h)=>a+h.hours,0);
      stats.push({ m, work, personal, hrs, total: work+personal });
      if(work+personal > maxMiles) maxMiles = work+personal;
    }
    const nowKey = todayISO().slice(0,7);
    const grid = $('yearGrid');
    grid.innerHTML = '<div class="year-grid">' + stats.map(s=>{
      const key = calYear + '-' + pad(s.m+1);
      const workPct = maxMiles > 0 ? (s.work / maxMiles) * 100 : 0;
      const personalPct = maxMiles > 0 ? (s.personal / maxMiles) * 100 : 0;
      return '<div class="month-card' + (key===nowKey?' current':'') + '" data-month="' + s.m + '">'
        + '<div class="month-card-name">' + monthNames[s.m] + '</div>'
        + '<div class="month-bar-track"><div class="seg-work" style="width:' + workPct + '%"></div><div class="seg-personal" style="width:' + personalPct + '%"></div></div>'
        + '<div class="month-card-stats">'
        + '<strong>' + s.total.toFixed(0) + '</strong> mi total<br>'
        + '<strong>' + s.hrs.toFixed(1) + '</strong> hrs worked'
        + '</div></div>';
    }).join('') + '</div>';

    grid.querySelectorAll('.month-card').forEach(card=>{
      card.addEventListener('click', ()=>{
        calMonth = Number(card.dataset.month);
        document.querySelectorAll('.cal-view-tab').forEach(t=>t.classList.toggle('active', t.dataset.calview==='month'));
        calViewMode = 'month';
        $('calMonthView').classList.remove('hidden');
        $('calYearView').classList.add('hidden');
        renderCalendar();
      });
    });
  }

  function renderCalendar(){
    const label = new Date(calYear, calMonth, 1).toLocaleDateString('en-GB',{month:'long', year:'numeric'});
    $('calMonthLabel').textContent = label;

    const firstDay = new Date(calYear, calMonth, 1);
    let startOffset = firstDay.getDay() - 1; // Monday = 0
    if(startOffset < 0) startOffset = 6;
    const daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
    const totalCells = Math.ceil((startOffset + daysInMonth) / 7) * 7;

    const grid = $('calGrid');
    let html = '';
    for(let i=0;i<totalCells;i++){
      const dayNum = i - startOffset + 1;
      if(dayNum < 1 || dayNum > daysInMonth){
        html += '<div class="cal-cell empty"></div>';
        continue;
      }
      const dateStr = calYear + '-' + pad(calMonth+1) + '-' + pad(dayNum);
      const isToday = dateStr === todayISO();
      const dayTrips = trips.filter(t=>t.date === dateStr);
      const dayHours = hoursEntries.filter(h=>h.date === dateStr).reduce((a,h)=>a+h.hours,0);
      const hasWork = dayTrips.some(t=>t.type==='work');
      const hasPersonal = dayTrips.some(t=>t.type==='personal');
      let dots = '';
      if(hasWork) dots += '<span class="dot work"></span>';
      if(hasPersonal) dots += '<span class="dot personal"></span>';
      const hoursBadge = dayHours > 0 ? '<span class="cal-hours-badge">' + dayHours.toFixed(1) + 'h</span>' : '';
      const isAway = jobsForDate(dateStr).length > 0;
      const isOver = dayOverExpected(dateStr);
      let cellClass = 'cal-cell';
      if(isToday) cellClass += ' today';
      if(isAway) cellClass += ' away';
      if(isOver) cellClass += ' over-expected';
      html += '<div class="' + cellClass + '" data-date="' + dateStr + '">'
        + '<div class="cal-daynum">' + dayNum + '</div>'
        + '<div class="cal-dots">' + dots + hoursBadge + '</div>'
        + '</div>';
    }
    grid.innerHTML = html;
    grid.querySelectorAll('.cal-cell:not(.empty)').forEach(cell=>{
      cell.addEventListener('click', ()=> openDayModal(cell.dataset.date));
    });
  }

  // ---------------- Day modal ----------------
  let modalDate = null;
  function openDayModal(dateStr){
    modalDate = dateStr;
    const d = new Date(dateStr+'T00:00:00');
    $('dayModalTitle').textContent = d.toLocaleDateString('en-GB',{weekday:'long', day:'numeric', month:'long'});

    const dayTrips = trips.filter(t=>t.date===dateStr);
    const dayHours = hoursEntries.filter(h=>h.date===dateStr);
    const dayJobs = jobsForDate(dateStr);
    let html = '';

    if(dayJobs.length > 0){
      const j = dayJobs[0];
      const actual = actualHoursForDate(dateStr);
      const over = j.expectedHours > 0 && actual > j.expectedHours;
      html += '<div class="overtime-banner ' + (over ? 'over' : 'under') + '" style="margin-bottom:14px;margin-top:0;">'
        + escapeHtml(j.title) + (j.location ? ' &middot; ' + escapeHtml(j.location) : '')
        + (j.expectedHours > 0 ? ' &mdash; expected ' + j.expectedHours.toFixed(1) + ' hrs, logged ' + actual.toFixed(1) + ' hrs'
          + (over ? ' (over)' : '') : '')
        + '</div>';
    }

    if(dayTrips.length === 0 && dayHours.length === 0 && dayJobs.length === 0){
      html = '<div class="empty-state"><strong>Nothing logged</strong>Add a trip or hours for this day below.</div>';
    }
    dayTrips.forEach(t=>{
      const route = (t.from || t.to) ? [t.from,t.to].filter(Boolean).join(' \u2192 ') : 'Trip';
      html += '<div class="day-entry"><div class="de-main"><strong>' + route + '</strong><div>' + t.distance.toFixed(1) + ' mi &middot; ' + (t.type==='work'?'Work':'Personal') + '</div></div>'
        + '<div style="display:flex;gap:2px;"><button class="edit-btn" onclick="window.__editTripFromModal(' + t.id + ')" aria-label="Edit">&#9998;</button>'
        + '<button class="del-btn" onclick="window.__deleteTrip(' + t.id + ');window.__reopenModal()" aria-label="Delete">&times;</button></div></div>';
    });
    dayHours.forEach(h=>{
      html += '<div class="day-entry"><div class="de-main"><strong>' + h.hours.toFixed(2) + ' hrs</strong>' + (h.notes ? '<div>' + escapeHtml(h.notes) + '</div>' : '') + '</div>'
        + '<div style="display:flex;gap:2px;"><button class="edit-btn" onclick="window.__editHoursFromModal(' + h.id + ')" aria-label="Edit">&#9998;</button>'
        + '<button class="del-btn" onclick="window.__deleteHours(' + h.id + ');window.__reopenModal()" aria-label="Delete">&times;</button></div></div>';
    });
    $('dayModalEntries').innerHTML = html;
    $('dayModalOverlay').classList.add('open');
  }
  window.__reopenModal = ()=>{ if(modalDate) setTimeout(()=>openDayModal(modalDate), 50); };

  $('dayModalClose').addEventListener('click', ()=> $('dayModalOverlay').classList.remove('open'));
  $('dayModalOverlay').addEventListener('click', (e)=>{ if(e.target === $('dayModalOverlay')) $('dayModalOverlay').classList.remove('open'); });

  $('dayAddTrip').addEventListener('click', ()=>{
    $('dayModalOverlay').classList.remove('open');
    $('tripDate').value = modalDate;
    switchView('trip');
  });
  $('dayAddHours').addEventListener('click', ()=>{
    $('dayModalOverlay').classList.remove('open');
    $('hoursDate').value = modalDate;
    const matches = jobsForDate(modalDate);
    if(matches.length > 0) $('hoursJob').value = matches[0].id;
    switchView('hours');
  });

  // ---------------- Add to Home Screen ----------------
  let deferredInstallPrompt = null;
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
  const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true;

  function setInstallStatus(msg){
    $('installStatus').textContent = msg || '';
  }

  if(isStandalone){
    $('installCard').classList.add('hidden');
  }

  window.addEventListener('beforeinstallprompt', (e)=>{
    e.preventDefault();
    deferredInstallPrompt = e;
  });

  $('installBtn').addEventListener('click', async ()=>{
    if(isStandalone){
      setInstallStatus('This is already added to your home screen.');
      return;
    }
    if(deferredInstallPrompt){
      deferredInstallPrompt.prompt();
      const choice = await deferredInstallPrompt.userChoice;
      deferredInstallPrompt = null;
      setInstallStatus(choice.outcome === 'accepted' ? 'Added to your home screen ✓' : '');
    }else if(isIOS){
      setInstallStatus('iOS doesn\u2019t allow one-tap install \u2014 tap the Share icon in Safari, then "Add to Home Screen".');
    }else{
      setInstallStatus('Your browser doesn\u2019t support one-tap install \u2014 check its menu for "Add to Home Screen" or "Install app".');
    }
  });

  updateGauge();
  loadProfiles();
  loadAll();
})();
</script>
</body>
</html>
