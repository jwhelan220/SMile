<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Mileage &amp; Hours Log</title>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Mileage Log">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#08070d">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.min.js"></script>
<style>
  :root{
    --bg:#08070d;
    --surface:#14111f;
    --surface-raised:#1b1729;
    --border:#2a2440;
    --purple:#8b5cf6;
    --purple-deep:#5b21b6;
    --purple-glow: rgba(139,92,246,0.45);
    --teal:#2dd4bf;
    --teal-glow: rgba(45,212,191,0.45);
    --amber:#f5a623;
    --amber-glow: rgba(245,166,35,0.4);
    --text:#f3f0fb;
    --text-muted:#948aad;
    --text-dim:#5f5678;
    --danger:#f0668a;
    --radius:14px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:
      radial-gradient(circle at 15% 0%, rgba(139,92,246,0.10), transparent 40%),
      radial-gradient(circle at 85% 100%, rgba(45,212,191,0.06), transparent 45%),
      var(--bg);
    color:var(--text);
    font-family:'Inter', sans-serif;
    min-height:100vh;
    padding:20px 16px 60px;
  }
  .app{max-width:1000px;margin:0 auto;}

  /* Header */
  .topbar{
    display:flex; align-items:flex-end; justify-content:space-between;
    margin-bottom:20px; flex-wrap:wrap; gap:12px;
    border-bottom:1px solid var(--border);
    padding-bottom:18px;
  }
  .brand{display:flex; align-items:center; gap:12px;}
  .brand-mark{
    width:38px;height:38px;border-radius:9px;
    background:linear-gradient(135deg,var(--purple),var(--purple-deep));
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 0 22px var(--purple-glow);
    flex-shrink:0;
  }
  .brand-mark svg{width:20px;height:20px;}
  .brand h1{font-family:'Space Grotesk',sans-serif;font-size:19px;font-weight:600;margin:0;letter-spacing:0.2px;}
  .brand p{margin:2px 0 0;font-size:12px;color:var(--text-muted);}
  .today{font-family:'Space Mono',monospace;font-size:11.5px;color:var(--text-dim);text-align:right;}

  /* Profile bar */
  .profile-bar{display:flex; gap:8px; align-items:center; margin-bottom:14px;}
  .profile-bar select{flex:1; min-width:0;}
  .profile-btn{padding:10px 12px; white-space:nowrap; flex-shrink:0;}
  #deleteProfileBtn:hover{border-color:var(--danger); color:var(--danger);}

  /* Nav */
  .nav{
    display:flex; gap:6px; background:var(--surface); border:1px solid var(--border);
    border-radius:12px; padding:5px; margin-bottom:20px; overflow-x:auto;
  }
  .nav-item{
    flex:1; text-align:center; padding:10px 8px; font-size:13px; font-weight:600;
    border-radius:8px; cursor:pointer; color:var(--text-muted); white-space:nowrap;
    transition:all .15s ease; font-family:'Space Grotesk',sans-serif; user-select:none;
  }
  .nav-item.active{background:linear-gradient(135deg,var(--purple),var(--purple-deep)); color:#fff; box-shadow:0 3px 14px var(--purple-glow);}

  .view{display:none;}
  .view.active{display:block;}

  .card{
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:var(--radius);
    padding:22px;
    margin-bottom:20px;
  }
  .card-head{
    font-family:'Space Grotesk',sans-serif;
    font-size:13px; font-weight:600; letter-spacing:0.6px;
    text-transform:uppercase; color:var(--text-muted);
    margin-bottom:16px;
    display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap;
  }

  /* Mode tabs */
  .mode-tabs{display:flex;gap:6px;margin-bottom:18px;background:var(--bg);padding:4px;border-radius:10px;border:1px solid var(--border);}
  .mode-tab, .cal-view-tab{
    flex:1; text-align:center; padding:8px 6px; font-size:12px; font-weight:500;
    border-radius:7px; cursor:pointer; color:var(--text-muted); transition:all .15s ease;
    user-select:none;
  }
  .mode-tab.active, .cal-view-tab.active{background:var(--surface-raised); color:var(--text); box-shadow:0 0 0 1px var(--border);}

  .field{display:flex;flex-direction:column;gap:6px;margin-bottom:14px;}
  .field label{font-size:12px;color:var(--text-muted);font-weight:500;}
  .row-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  input, textarea, select{
    background:var(--bg); border:1px solid var(--border); border-radius:9px;
    padding:10px 12px; color:var(--text); font-size:14px; font-family:'Inter',sans-serif;
    outline:none; transition:border-color .15s ease;
    width:100%;
  }
  input:focus, textarea:focus, select:focus{border-color:var(--purple);}
  textarea{resize:vertical;min-height:56px;}
  .hidden{display:none !important;}
  .hint{font-size:11.5px;color:var(--text-dim);margin-top:-8px;margin-bottom:14px;line-height:1.4;}

  /* Address autocomplete */
  .ac-wrap{position:relative;}
  .ac-suggestions{
    position:absolute; top:calc(100% + 4px); left:0; right:0; z-index:30;
    background:var(--surface-raised); border:1px solid var(--border); border-radius:9px;
    max-height:200px; overflow-y:auto; display:none; box-shadow:0 8px 24px rgba(0,0,0,0.4);
  }
  .ac-suggestions.open{display:block;}
  .ac-item{padding:10px 12px; font-size:12.5px; line-height:1.4; cursor:pointer; border-bottom:1px solid var(--border);}
  .ac-item:last-child{border-bottom:none;}
  .ac-item:hover{background:var(--bg); color:var(--text);}

  /* Route info */
  .route-info{background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:12px 14px; margin-bottom:14px;}
  .route-info-row{display:flex; justify-content:space-between; align-items:center; font-size:13px; padding:4px 0;}
  .route-info-row span{color:var(--text-muted);}
  .route-info-row strong{font-family:'Space Mono',monospace; color:var(--text);}

  .btn-secondary{
    background:var(--bg); border:1px solid var(--border); color:var(--text);
    padding:10px 16px; border-radius:9px; font-size:13px; font-weight:600; cursor:pointer;
    font-family:'Space Grotesk',sans-serif; transition:border-color .15s ease;
  }
  .btn-secondary:hover{border-color:var(--purple);}
  .btn-secondary:disabled{opacity:0.5;cursor:default;}

  /* Gauge */
  .gauge-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:18px 0 6px;}
  .gauge{position:relative;width:170px;height:170px;}
  .gauge svg{width:100%;height:100%;transform:rotate(-90deg);}
  .gauge circle{fill:none;stroke-width:10;}
  .gauge .track{stroke:var(--border);}
  .gauge .fill{stroke-linecap:round;transition:stroke-dashoffset 0.7s cubic-bezier(.4,1.4,.4,1), stroke .3s ease;}
  .gauge-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
  .gauge-value{font-family:'Space Mono',monospace;font-size:28px;font-weight:700;letter-spacing:-1px;transition:color .2s ease;}
  .gauge-unit{font-size:11px;color:var(--text-muted);letter-spacing:1px;text-transform:uppercase;margin-top:2px;}
  .gauge-status{font-size:11px;color:var(--text-dim);margin-top:10px;min-height:14px;text-align:center;}

  /* Type toggle - tap lever styled */
  .type-toggle-wrap{margin:18px 0 20px;}
  .type-toggle{display:flex; align-items:center; justify-content:center; gap:14px;}
  .type-label{font-size:13px;font-weight:600;color:var(--text-dim);transition:color .2s ease;min-width:56px;text-align:center;}
  .type-label.on{color:var(--text);}
  .tap-switch{
    position:relative; width:64px; height:32px; border-radius:20px;
    border:1px solid var(--border); background:var(--bg); cursor:pointer;
    padding:0; flex-shrink:0;
  }
  .tap-handle{
    position:absolute; top:3px; left:3px; width:24px; height:24px; border-radius:50%;
    background:linear-gradient(135deg,var(--teal),#1a9e8e);
    box-shadow:0 0 12px var(--teal-glow);
    transition:transform .25s cubic-bezier(.4,1.4,.4,1), background .25s ease, box-shadow .25s ease;
  }
  .tap-switch[data-state="work"] .tap-handle{
    transform:translateX(32px);
    background:linear-gradient(135deg,var(--purple),var(--purple-deep));
    box-shadow:0 0 12px var(--purple-glow);
  }

  .btn-primary{
    width:100%; padding:13px; border:none; border-radius:10px; cursor:pointer;
    background:linear-gradient(135deg,var(--purple),var(--purple-deep));
    color:#fff; font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:14px;
    letter-spacing:0.3px; box-shadow:0 4px 18px var(--purple-glow);
    transition:transform .12s ease, box-shadow .12s ease;
  }
  .btn-primary:hover{transform:translateY(-1px); box-shadow:0 6px 22px var(--purple-glow);}
  .btn-primary:active{transform:translateY(0);}
  .btn-primary.teal{background:linear-gradient(135deg,var(--teal),#1a9e8e); box-shadow:0 4px 18px var(--teal-glow);}

  /* Dashboard stats */
  .summary-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
  @media(max-width:650px){.summary-grid{grid-template-columns:1fr;}}
  .stat{background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:16px;}
  .stat-label{font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.6px; margin-bottom:8px; display:flex; align-items:center; gap:6px;}
  .dot{width:7px;height:7px;border-radius:50%;display:inline-block;flex-shrink:0;}
  .dot.work{background:var(--purple);box-shadow:0 0 6px var(--purple-glow);}
  .dot.personal{background:var(--teal);box-shadow:0 0 6px var(--teal-glow);}
  .dot.hours{background:var(--amber);box-shadow:0 0 6px var(--amber-glow);}
  .stat-value{font-family:'Space Mono',monospace; font-size:23px; font-weight:700;}
  .stat-value span{font-size:13px;color:var(--text-muted);font-weight:400;}

  .split-bar{height:8px;border-radius:5px;overflow:hidden;display:flex;margin-top:16px;background:var(--bg);border:1px solid var(--border);}
  .split-bar .seg-work{background:linear-gradient(90deg,var(--purple-deep),var(--purple));}
  .split-bar .seg-personal{background:linear-gradient(90deg,var(--teal),#1a9e8e);}
  .split-caption{display:flex;justify-content:space-between;font-size:11px;color:var(--text-dim);margin-top:8px;}

  /* Hours progress */
  .hours-progress{margin-top:8px;}
  .hours-block-label{font-size:11.5px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.4px;margin-bottom:4px;}
  .hours-bar-track{height:10px;border-radius:6px;background:var(--bg);border:1px solid var(--border);overflow:hidden;margin-top:10px;}
  .hours-bar-fill{height:100%;border-radius:6px;background:linear-gradient(90deg,var(--purple-deep),var(--purple));transition:width .5s ease;}
  .hours-bar-fill.over{background:linear-gradient(90deg,var(--amber),#e08a1a);}
  .hours-caption{display:flex;justify-content:space-between;font-size:11.5px;color:var(--text-dim);margin-top:8px;}
  .overtime-banner{
    margin-top:14px;padding:12px 14px;border-radius:10px;font-size:13px;font-weight:600;
    display:flex;align-items:center;justify-content:space-between;
  }
  .overtime-banner.over{background:rgba(245,166,35,0.12); color:#f5c877; border:1px solid rgba(245,166,35,0.3);}
  .overtime-banner.under{background:rgba(139,92,246,0.1); color:#c4b5fd; border:1px solid rgba(139,92,246,0.25);}

  .contracted-row{display:flex;align-items:center;gap:10px;margin-top:14px;font-size:12.5px;color:var(--text-muted);}
  .contracted-row input{width:80px;padding:6px 10px;font-size:13px;}

  /* History */
  .history-head{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:16px;}
  .filter-tabs{display:flex;gap:6px;}
  .filter-tab{padding:6px 12px;font-size:12px;border-radius:7px;border:1px solid var(--border);color:var(--text-muted);cursor:pointer;background:var(--bg);}
  .filter-tab.active{color:var(--text);border-color:var(--purple);background:rgba(139,92,246,0.12);}

  .trip-row{
    display:grid; grid-template-columns:auto 1fr auto auto auto; align-items:center; gap:10px;
    padding:13px 4px; border-bottom:1px solid var(--border);
  }
  .trip-row:last-child{border-bottom:none;}
  .trip-date{font-family:'Space Mono',monospace; font-size:12px; color:var(--text-muted); white-space:nowrap;}
  .trip-info{min-width:0;}
  .trip-info .route{font-size:14px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .trip-info .purpose{font-size:12px;color:var(--text-muted);margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  @media(max-width:480px){
    .trip-tag .tag-label{display:none;}
    .trip-tag{padding:4px 6px;}
  }
  .trip-tag{
    font-size:11px; font-weight:600; padding:4px 10px; border-radius:20px; letter-spacing:0.3px;
    display:flex; align-items:center; gap:5px; white-space:nowrap;
  }
  .trip-tag.work{background:rgba(139,92,246,0.15); color:#c4b5fd;}
  .trip-tag.personal{background:rgba(45,212,191,0.15); color:#7fe9dc;}
  .trip-dist{font-family:'Space Mono',monospace; font-weight:700; font-size:14px; text-align:right; white-space:nowrap;}
  .trip-actions{display:flex;justify-content:flex-end;gap:2px;}
  .del-btn{
    background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:16px;padding:4px 8px;border-radius:6px;
    transition:color .15s ease, background .15s ease;
  }
  .del-btn:hover{color:var(--danger); background:rgba(240,102,138,0.1);}
  .edit-btn{
    background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:14px;padding:4px 8px;border-radius:6px;
    transition:color .15s ease, background .15s ease;
  }
  .edit-btn:hover{color:var(--purple); background:rgba(139,92,246,0.1);}

  /* Address chips */
  .chip-row{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;}
  .chip{
    font-size:12px;padding:6px 12px;border-radius:20px;border:1px solid var(--border);
    background:var(--bg);color:var(--text-muted);cursor:pointer;white-space:nowrap;
    max-width:180px;overflow:hidden;text-overflow:ellipsis;
    transition:border-color .15s ease, color .15s ease;
  }
  .chip:hover{border-color:var(--purple); color:var(--text);}

  /* GPS trip */
  .gps-status{
    background:var(--bg); border:1px solid var(--purple); border-radius:10px; padding:12px 14px;
    margin-bottom:14px; font-size:12.5px; color:var(--text-muted); display:none; line-height:1.5;
  }
  .gps-status strong{color:var(--text);}
  .gps-cancel{background:none;border:none;color:var(--text-dim);font-size:11px;text-decoration:underline;cursor:pointer;padding:6px 0 0;display:block;}
  .gps-cancel:hover{color:var(--danger);}

  .empty-state{padding:36px 10px;text-align:center;color:var(--text-dim);font-size:13px;}
  .empty-state strong{display:block;color:var(--text-muted);font-size:14px;margin-bottom:4px;font-family:'Space Grotesk',sans-serif;}

  /* Calendar */
  .cal-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
  .cal-nav-btn{
    width:32px;height:32px;border-radius:8px;border:1px solid var(--border);background:var(--bg);
    color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;
  }
  .cal-nav-btn:hover{border-color:var(--purple);}
  .cal-month-label{font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:15px;}
  .cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;}
  .cal-dow{text-align:center;font-size:10.5px;color:var(--text-dim);font-weight:600;letter-spacing:0.4px;padding-bottom:6px;}
  .cal-cell{
    aspect-ratio:1;border-radius:9px;border:1px solid var(--border);background:var(--bg);
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;
    cursor:pointer;position:relative;transition:border-color .15s ease, background .15s ease;
    padding:4px;
  }
  .cal-cell:hover{border-color:var(--purple);}
  .cal-cell.empty{visibility:hidden;cursor:default;}
  .cal-cell.today{border-color:var(--purple); box-shadow:0 0 0 1px var(--purple);}
  .cal-cell.away{background:rgba(139,92,246,0.09); border-color:rgba(139,92,246,0.3);}
  .cal-cell.over-expected{border-color:var(--amber); box-shadow:0 0 0 1px var(--amber), 0 0 10px var(--amber-glow);}
  .cal-daynum{font-size:12.5px;font-weight:600;font-family:'Space Grotesk',sans-serif;}
  .cal-dots{display:flex;gap:3px;align-items:center;flex-wrap:wrap;justify-content:center;}
  .cal-hours-badge{font-size:9px;font-family:'Space Mono',monospace;color:var(--amber);}
  .cal-legend{display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;font-size:11px;color:var(--text-dim);}
  .cal-legend span{display:flex;align-items:center;gap:5px;}
  .cal-legend .sw{width:11px;height:11px;border-radius:3px;display:inline-block;}
  .cal-legend .sw.away{background:rgba(139,92,246,0.25);border:1px solid rgba(139,92,246,0.5);}
  .cal-legend .sw.over{background:rgba(245,166,35,0.2);border:1px solid var(--amber);}

  /* Year view */
  .year-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
  @media(max-width:560px){.year-grid{grid-template-columns:repeat(2,1fr);}}
  .month-card{
    background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:12px;
    cursor:pointer; transition:border-color .15s ease;
  }
  .month-card:hover{border-color:var(--purple);}
  .month-card.current{border-color:var(--purple); box-shadow:0 0 0 1px var(--purple);}
  .month-card-name{font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:13px; margin-bottom:8px;}
  .month-bar-track{height:8px; border-radius:5px; overflow:hidden; display:flex; background:var(--surface-raised); border:1px solid var(--border);}
  .month-bar-track .seg-work{background:linear-gradient(90deg,var(--purple-deep),var(--purple));}
  .month-bar-track .seg-personal{background:linear-gradient(90deg,var(--teal),#1a9e8e);}
  .month-card-stats{margin-top:8px; font-size:10.5px; color:var(--text-dim); line-height:1.6;}
  .month-card-stats strong{color:var(--text); font-family:'Space Mono',monospace; font-weight:700;}

  /* Trends */
  .chart-wrap{position:relative; height:280px; margin-top:6px;}
  .trend-row{
    display:grid; grid-template-columns:auto 1fr 1fr 1fr; align-items:center; gap:12px;
    padding:11px 4px; border-bottom:1px solid var(--border); font-size:12.5px;
  }
  .trend-row:last-child{border-bottom:none;}
  .trend-row.head{color:var(--text-muted); font-size:11px; text-transform:uppercase; letter-spacing:0.4px; font-weight:600;}
  .trend-row .tm{font-family:'Space Grotesk',sans-serif; font-weight:600; color:var(--text); white-space:nowrap;}
  .trend-row span:not(.tm){font-family:'Space Mono',monospace; color:var(--text-muted);}

  /* Job cards */
  .job-card{border:1px solid var(--border); border-radius:10px; padding:14px; margin-bottom:10px; background:var(--bg);}
  .job-card:last-child{margin-bottom:0;}
  .job-card-head{display:flex; align-items:flex-start; justify-content:space-between; gap:10px;}
  .job-card-title{font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:14.5px;}
  .job-card-meta{font-size:12px; color:var(--text-muted); margin-top:3px;}
  .job-card-stats{display:flex; gap:16px; margin-top:10px; font-size:12px; color:var(--text-dim);}
  .job-card-stats strong{color:var(--text); font-family:'Space Mono',monospace;}
  .job-status{font-size:11px; font-weight:600; padding:3px 9px; border-radius:20px; white-space:nowrap;}
  .job-status.over{background:rgba(245,166,35,0.15); color:#f5c877;}
  .job-status.under{background:rgba(139,92,246,0.12); color:#c4b5fd;}

  /* Day modal */
  .modal-overlay{
    position:fixed;inset:0;background:rgba(5,4,10,0.75);backdrop-filter:blur(3px);
    display:none;align-items:flex-end;justify-content:center;z-index:100;
  }
  .modal-overlay.open{display:flex;}
  @media(min-width:640px){.modal-overlay{align-items:center;}}
  .modal{
    background:var(--surface); border:1px solid var(--border); border-radius:16px 16px 0 0;
    max-width:520px; width:100%; max-height:82vh; overflow-y:auto; padding:22px;
  }
  @media(min-width:640px){.modal{border-radius:16px;}}
  .modal-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
  .modal-title{font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;}
  .modal-close{background:none;border:none;color:var(--text-muted);font-size:20px;cursor:pointer;padding:2px 8px;}
  .modal-actions{display:flex;gap:10px;margin-top:16px;}
  .modal-actions .btn-primary, .modal-actions .btn-secondary{flex:1;width:auto;}
  .day-entry{
    display:flex;align-items:center;justify-content:space-between;gap:10px;
    padding:10px 0;border-bottom:1px solid var(--border);font-size:13px;
  }
  .day-entry:last-child{border-bottom:none;}
  .day-entry .de-main{flex:1;}
  .day-entry .de-main strong{font-size:13.5px;}
