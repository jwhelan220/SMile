  function editTrip(id){
    const t = trips.find(x=>x.id===id);
    if(!t) return;
    editingTripId = id;
    switchView('trip');
    document.querySelectorAll('.mode-tab').forEach(tab=>tab.classList.toggle('active', tab.dataset.mode==='manual'));
