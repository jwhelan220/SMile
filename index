      <div class="gauge-wrap">
        <div class="gauge">
          <svg viewBox="0 0 120 120">
            <circle class="track" cx="60" cy="60" r="52"></circle>
            <circle class="fill" id="gaugeFill" cx="60" cy="60" r="52" stroke="#8b5cf6"
              stroke-dasharray="326.7" stroke-dashoffset="326.7"></circle>
          </svg>
          <div class="gauge-center">
            <div class="gauge-value" id="gaugeValue">0.0</div>
            <div class="gauge-unit">miles</div>
          </div>
        </div>
        <div class="gauge-status" id="gaugeStatus"></div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">Trip details</div>

      <div class="field">
        <label for="purpose">Purpose / notes</label>
