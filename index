  // ---------------- Trends ----------------
  let trendsChartInstance = null;

  function computeMonthlySeries(){
    const allDates = trips.map(t=>t.date).concat(hoursEntries.map(h=>h.date));
    if(allDates.length === 0) return { keys: [], labels: [], work: [], personal: [], hours: [] };
    const minKey = allDates.map(monthKeyOf).sort()[0];
    const maxKey = monthKeyOf(todayISO());
    const keys = [];
    let [y,m] = minKey.split('-').map(Number);
    const [maxY,maxM] = maxKey.split('-').map(Number);
    while(y < maxY || (y === maxY && m <= maxM)){
      keys.push(y + '-' + pad(m));
      m++;
      if(m > 12){ m = 1; y++; }
    }
    const shortLabels = keys.map(k=>{
      const [ky,km] = k.split('-').map(Number);
      return new Date(ky, km-1, 1).toLocaleDateString('en-GB',{month:'short'}) + " '" + String(ky).slice(2);
    });
    const work = keys.map(k=> trips.filter(t=>monthKeyOf(t.date)===k && t.type==='work').reduce((a,t)=>a+t.distance,0));
    const personal = keys.map(k=> trips.filter(t=>monthKeyOf(t.date)===k && t.type==='personal').reduce((a,t)=>a+t.distance,0));
    const hours = keys.map(k=> hoursEntries.filter(h=>monthKeyOf(h.date)===k).reduce((a,h)=>a+h.hours,0));
    return { keys, labels: shortLabels, work, personal, hours };
  }

  function renderTrends(){
    const data = computeMonthlySeries();
    const canvas = $('trendsChart');
    if(data.keys.length === 0){
      $('trendsTable').innerHTML = '<div class="empty-state"><strong>No data yet</strong>Log some trips or hours to see trends here.</div>';
      return;
    }
    if(typeof Chart === 'undefined'){
      $('trendsTable').innerHTML = '<div class="empty-state"><strong>Chart library did not load</strong>Check your internet connection and reopen this page.</div>';
      return;
    }
    if(trendsChartInstance){ trendsChartInstance.destroy(); }
    const gridColor = 'rgba(148,138,173,0.15)';
    const textColor = '#948aad';
    trendsChartInstance = new Chart(canvas.getContext('2d'), {
      data: {
        labels: data.labels,
        datasets: [
          { type:'bar', label:'Work miles', data: data.work, backgroundColor:'#8b5cf6', stack:'miles', yAxisID:'y', borderRadius:3 },
          { type:'bar', label:'Personal miles', data: data.personal, backgroundColor:'#2dd4bf', stack:'miles', yAxisID:'y', borderRadius:3 },
          { type:'line', label:'Hours worked', data: data.hours, borderColor:'#f5a623', backgroundColor:'#f5a623', yAxisID:'y1', tension:0.3, pointRadius:3, pointBackgroundColor:'#f5a623' }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode:'index', intersect:false },
        plugins: {
          legend: { labels:{ color:textColor, font:{ family:'Inter', size:11 } } }
        },
        scales: {
          x: { stacked:true, ticks:{ color:textColor, font:{ family:'Space Mono', size:10 } }, grid:{ color:gridColor } },
          y: { stacked:true, position:'left', ticks:{ color:textColor, font:{ size:10 } }, grid:{ color:gridColor }, title:{ display:true, text:'Miles', color:textColor } },
          y1: { position:'right', ticks:{ color:textColor, font:{ size:10 } }, grid:{ display:false }, title:{ display:true, text:'Hours', color:textColor } }
        }
      }
    });

    $('trendsTable').innerHTML = '<div class="trend-row head"><span>Month</span><span>Work mi</span><span>Personal mi</span><span>Hours</span></div>'
      + data.keys.map((k,i)=>'<div class="trend-row"><span class="tm">' + data.labels[i] + '</span><span>' + data.work[i].toFixed(1) + '</span><span>' + data.personal[i].toFixed(1) + '</span><span>' + data.hours[i].toFixed(1) + '</span></div>').join('');
  }

