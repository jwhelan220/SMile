      <div class="type-toggle-wrap">
        <div class="type-toggle">
          <span class="type-label on" id="labelPersonal">Personal</span>
          <button class="tap-switch" id="typeToggle" data-state="personal" aria-label="Toggle trip type">
            <span class="tap-handle"></span>
          </button>
          <span class="type-label" id="labelWork">Work</span>
