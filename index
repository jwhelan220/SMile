  $('addTripBtn').addEventListener('click', async ()=>{
    const distance = computeDistance();
    if(distance <= 0){
      $('gaugeValue').style.color = '#f0668a';
      setTimeout(()=>{ $('gaugeValue').style.color = ''; }, 700);
      setGaugeStatus('Enter a valid distance before logging.', true);
      return;
    }
    const data = {
      date: $('tripDate').value || todayISO(),
      from: $('fromLoc').value.trim(),
      to: $('toLoc').value.trim(),
      purpose: $('purpose').value.trim(),
      type: typeState,
      distance: Math.round(distance * 10) / 10,
      mode: mode
    };

    const wasEditing = !!editingTripId;
    if(wasEditing){
      const idx = trips.findIndex(t=>t.id === editingTripId);
      if(idx > -1) trips[idx] = Object.assign({ id: editingTripId }, data);
      editingTripId = null;
      setTripFormEditingUI(false);
    }else{
