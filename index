    <div class="nav-item" data-view="trip">Log Trip</div>
    <div class="nav-item" data-view="hours">Log Hours</div>
    <div class="nav-item" data-view="trends">Trends</div>
  </div>

  <!-- ============ DASHBOARD ============ -->
  <div class="view active" id="view-dashboard">

    <div class="card">
      <div class="card-head">
        <span id="dashMonthLabel">This month</span>
      </div>
      <div class="summary-grid">
        <div class="stat">
          <div class="stat-label"><span class="dot work"></span>Work miles</div>
          <div class="stat-value" id="workTotal">0.0 <span>mi</span></div>
        </div>
        <div class="stat">
          <div class="stat-label"><span class="dot personal"></span>Personal miles</div>
          <div class="stat-value" id="personalTotal">0.0 <span>mi</span></div>
        </div>
        <div class="stat">
          <div class="stat-label"><span class="dot hours"></span>Hours worked</div>
          <div class="stat-value" id="hoursTotal">0.0 <span>hrs</span></div>
        </div>
      </div>
      <div class="split-bar">
        <div class="seg-work" id="segWork" style="width:0%"></div>
        <div class="seg-personal" id="segPersonal" style="width:0%"></div>
      </div>
      <div class="split-caption">
        <span id="workPct">0% work</span>
        <span id="personalPct">0% personal</span>
      </div>
    </div>

    <div class="card">
      <div class="card-head">Away from home</div>
      <div class="summary-grid" style="grid-template-columns:1fr 1fr;">
        <div class="stat">
          <div class="stat-label">Days away this month</div>
          <div class="stat-value" id="awayDaysTotal">0 <span>days</span></div>
        </div>
        <div class="stat">
          <div class="stat-label">Jobs this month</div>
          <div class="stat-value" id="awayJobsTotal">0</div>
        </div>
      </div>
      <div class="overtime-banner under hidden" id="currentJobBanner"></div>
    </div>

    <div class="card">
      <div class="card-head">Hours vs contract</div>

      <div class="hours-block">
        <div class="hours-block-label">This week (Mon&ndash;Sun) &mdash; clocked weekly</div>
        <div class="hours-progress">
          <div class="hours-bar-track"><div class="hours-bar-fill" id="weekBarFill" style="width:0%"></div></div>
          <div class="hours-caption">
            <span id="weekCaptionLeft">0.0 hrs logged</span>
            <span id="weekCaptionRight">40 hrs/week</span>
          </div>
        </div>
        <div class="overtime-banner under" id="weekOvertimeBanner">On track &mdash; 0.0 hrs to go</div>
      </div>

      <div class="hours-block" style="margin-top:20px;">
        <div class="hours-block-label">This month &mdash; paid monthly</div>
        <div class="hours-progress">
          <div class="hours-bar-track"><div class="hours-bar-fill" id="hoursBarFill" style="width:0%"></div></div>
          <div class="hours-caption">
            <span id="hoursCaptionLeft">0.0 hrs logged</span>
            <span id="hoursCaptionRight">160 hrs contracted</span>
          </div>
        </div>
        <div class="overtime-banner under" id="overtimeBanner">On track &mdash; 0.0 hrs to go</div>
      </div>

      <div class="contracted-row">
        Weekly hours target:
        <input type="number" id="weeklyHours" value="40" min="0" step="1">
      </div>
      <div class="contracted-row">
        Monthly contracted hours:
        <input type="number" id="contractedHours" value="160" min="0" step="1">
      </div>
    </div>

    <div class="card">
      <div class="history-head">
        <div class="card-head" style="margin-bottom:0;">Trip history</div>
        <div class="filter-tabs">
          <div class="filter-tab active" data-filter="all">All</div>
          <div class="filter-tab" data-filter="work">Work</div>
          <div class="filter-tab" data-filter="personal">Personal</div>
        </div>
      </div>
      <div id="tripList"></div>
    </div>

    <div class="card">
      <div class="card-head">Reports</div>
      <div class="hint" style="margin-top:-4px;">Export a clean PDF for a chosen month &mdash; a mileage log to send to your line manager, or an hours log for your own TOIL tracking.</div>

      <div class="field">
        <label for="reporterName">Your name (shown on the PDF)</label>
        <input type="text" id="reporterName" placeholder="e.g. Joe Smith">
      </div>

      <div class="field">
        <label for="reportMonth">Report month</label>
        <select id="reportMonth"></select>
      </div>

      <div class="row-2">
        <button class="btn-secondary" id="exportTripsBtn">Export trip log (PDF)</button>
        <button class="btn-secondary" id="exportHoursBtn">Export hours log (PDF)</button>
