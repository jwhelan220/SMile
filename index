</style>
</head>
<body>
<div class="app">

  <div class="topbar">
    <div class="brand">
      <div class="brand-mark">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 17L9 8L13 14L16 9L20 17" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div>
        <h1>Mileage &amp; Hours Log</h1>
        <p>Company vehicle &middot; work &amp; personal</p>
      </div>
    </div>
    <div class="today" id="todayDate"></div>
  </div>

  <div class="profile-bar">
    <select id="profileSelect"></select>
