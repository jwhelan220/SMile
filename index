    if(gpsStartCoord){
      $('startGpsBtn').classList.add('hidden');
      $('endGpsBtn').classList.remove('hidden');
      $('gpsStatusBox').style.display = 'block';
      $('gpsStatusText').innerHTML = 'Trip in progress since <strong>' + new Date(gpsStartTime).toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}) + '</strong> from <strong>' + escapeHtml(gpsFromAddr) + '</strong>';
    }else{
      $('startGpsBtn').classList.remove('hidden');
      $('endGpsBtn').classList.add('hidden');
      $('gpsStatusBox').style.display = 'none';
    }
  }

  async function saveActiveGpsTrip(){
    rawSet(pKey('activeGpsTrip'), JSON.stringify({ coord: gpsStartCoord, time: gpsStartTime, addr: gpsFromAddr }));
  }
  async function clearActiveGpsTrip(){
