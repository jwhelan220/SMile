  function renderJobsList(){
    const list = $('jobsList');
    if(jobs.length === 0){
      list.innerHTML = '<div class="empty-state"><strong>No jobs logged yet</strong>Add a job above to start tracking time away from home.</div>';
      return;
    }
    const sorted = jobs.slice().sort((a,b)=> b.startDate.localeCompare(a.startDate));
    list.innerHTML = sorted.map(j=>{
      const days = jobDaysCount(j);
      const expectedTotal = j.expectedHours * days;
      const actualTotal = hoursEntries.filter(h => h.date >= j.startDate && h.date <= j.endDate).reduce((a,h)=>a+h.hours,0);
      const diff = actualTotal - expectedTotal;
      const isOver = expectedTotal > 0 && diff > 0;
      const statusHtml = expectedTotal > 0
        ? '<span class="job-status ' + (isOver ? 'over' : 'under') + '">' + (isOver ? '+' + diff.toFixed(1) + ' hrs over' : (diff===0 ? 'On target' : diff.toFixed(1) + ' hrs under')) + '</span>'
        : '';
      return '<div class="job-card">'
        + '<div class="job-card-head"><div>'
        + '<div class="job-card-title">' + escapeHtml(j.title) + '</div>'
        + '<div class="job-card-meta">' + (j.location ? escapeHtml(j.location) + ' &middot; ' : '') + j.startDate + ' to ' + j.endDate + ' (' + days + (days===1?' day':' days') + ' away)</div>'
        + '</div>'
        + '<div style="display:flex;align-items:center;gap:2px;">' + statusHtml
        + '<button class="edit-btn" onclick="window.__editJob(' + j.id + ')" aria-label="Edit job">&#9998;</button>'
        + '<button class="del-btn" onclick="window.__deleteJob(' + j.id + ')" aria-label="Delete job">&times;</button></div>'
        + '</div>'
        + '<div class="job-card-stats">'
