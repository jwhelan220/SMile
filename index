      <button class="btn-primary" id="addTripBtn">Log trip</button>
      <button class="btn-secondary hidden" id="cancelTripEditBtn" style="width:100%;margin-top:10px;">Cancel edit</button>
    </div>
  </div>

  <!-- ============ LOG HOURS ============ -->
  <div class="view" id="view-hours">
    <div class="card">
      <div class="card-head">Log hours worked</div>
      <div class="field">
        <label for="hoursDate">Date</label>
        <input type="date" id="hoursDate">
      </div>
      <div class="field">
        <label for="hoursWorked">Hours worked</label>
        <input type="number" id="hoursWorked" placeholder="e.g. 8.5" min="0" step="0.25">
      </div>
      <div class="field">
        <label for="hoursJob">Job (optional)</label>
        <select id="hoursJob"><option value="">No job / general hours</option></select>
      </div>
      <div class="field">
        <label for="hoursNotes">Notes</label>
        <textarea id="hoursNotes" placeholder="e.g. Event build &amp; teardown"></textarea>
      </div>
      <button class="btn-primary teal" id="addHoursBtn">Log hours</button>
      <button class="btn-secondary hidden" id="cancelHoursEditBtn" style="width:100%;margin-top:10px;">Cancel edit</button>
    </div>

    <div class="card">
      <div class="card-head">Hours history</div>
      <div id="hoursList"></div>
    </div>
  </div>

  <!-- ============ TRENDS ============ -->
  <div class="view" id="view-trends">
    <div class="card">
      <div class="card-head">Miles &amp; hours since you started</div>
      <div class="hint" style="margin-top:-4px;">Every month you've logged data for, side by side &mdash; work miles, personal miles, and hours worked.</div>
      <div class="chart-wrap">
        <canvas id="trendsChart"></canvas>
      </div>
    </div>

    <div class="card">
      <div class="card-head">Month by month</div>
      <div id="trendsTable"></div>
    </div>
  </div>

</div>

<!-- Day detail modal -->
<div class="modal-overlay" id="dayModalOverlay">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-title" id="dayModalTitle">Day</div>
      <button class="modal-close" id="dayModalClose">&times;</button>
    </div>
    <div id="dayModalEntries"></div>
    <div class="modal-actions">
      <button class="btn-secondary" id="dayAddTrip">+ Trip</button>
      <button class="btn-secondary" id="dayAddHours">+ Hours</button>
    </div>
  </div>
</div>
<script>
(function(){
  const CIRC = 2 * Math.PI * 52;
  const $ = id => document.getElementById(id);
  const todayISO = () => new Date().toISOString().slice(0,10);
  const MI_PER_METER = 1 / 1609.344;

  let profiles = [];
  let activeProfileId = null;

  let trips = [];
  let hoursEntries = [];
  let jobs = [];
  let contractedHours = 160;
  let weeklyHours = 40;
  let reporterName = '';

  let mode = 'odometer';
  let filter = 'all';
  let typeState = 'personal';
  let currentDistance = 0;
  let addressDistance = 0;
  let addressDuration = 0; // minutes
  let fromCoord = null;
  let toCoord = null;
  let activeAddressField = 'fromLoc';

  let editingTripId = null;
  let editingHoursId = null;
  let editingJobId = null;

  let gpsStartCoord = null;
  let gpsStartTime = null;
  let gpsFromAddr = '';

  let calYear, calMonth; // 0-indexed month for calendar view
  const now = new Date();
  calYear = now.getFullYear();
  calMonth = now.getMonth();

  $('todayDate').textContent = now.toLocaleDateString('en-GB', { weekday:'short', day:'numeric', month:'short', year:'numeric' });
  $('tripDate').value = todayISO();
  $('hoursDate').value = todayISO();
  $('jobStart').value = todayISO();
  $('jobEnd').value = todayISO();

  // ---------------- Storage (localStorage, scoped per profile) ----------------
  function rawGet(key){
    try{ return localStorage.getItem(key); }catch(e){ return null; }
  }
  function rawSet(key, value){
    try{ localStorage.setItem(key, value); return true; }catch(e){ console.error(e); return false; }
  }
  function rawDelete(key){
    try{ localStorage.removeItem(key); return true; }catch(e){ return false; }
  }
  function pKey(base){ return base + ':' + activeProfileId; }

  function loadProfiles(){
    try{
      const raw = rawGet('app:profiles');
      profiles = raw ? JSON.parse(raw) : [];
    }catch(e){ profiles = []; }
    activeProfileId = rawGet('app:activeProfileId');
    if(!activeProfileId || !profiles.some(p=>p.id === activeProfileId)){
      activeProfileId = profiles.length > 0 ? profiles[0].id : null;
    }
    if(profiles.length === 0){
      const name = (window.prompt('Welcome — what name should this profile be saved under?', '') || 'Me').trim() || 'Me';
      const id = 'p' + Date.now();
      profiles = [{ id, name }];
      activeProfileId = id;
      rawSet('app:profiles', JSON.stringify(profiles));
      rawSet('app:activeProfileId', activeProfileId);
    }
  }

  function renderProfileSelect(){
    const sel = $('profileSelect');
    sel.innerHTML = profiles.map(p=>'<option value="'+p.id+'">'+escapeHtml(p.name)+'</option>').join('');
    sel.value = activeProfileId;
  }

  async function switchProfile(id){
    activeProfileId = id;
    rawSet('app:activeProfileId', activeProfileId);
    editingTripId = null; editingHoursId = null; editingJobId = null;
    gpsStartCoord = null; gpsStartTime = null; gpsFromAddr = '';
    await loadAll();
  }

  $('profileSelect').addEventListener('change', ()=>{ switchProfile($('profileSelect').value); });

  $('addProfileBtn').addEventListener('click', async ()=>{
    const name = (window.prompt('New profile name:', '') || '').trim();
    if(!name) return;
    const id = 'p' + Date.now();
    profiles.push({ id, name });
    rawSet('app:profiles', JSON.stringify(profiles));
    renderProfileSelect();
    await switchProfile(id);
  });

  $('deleteProfileBtn').addEventListener('click', async ()=>{
    if(profiles.length <= 1){ window.alert('You need at least one profile.'); return; }
    const current = profiles.find(p=>p.id===activeProfileId);
    if(!window.confirm('Delete profile "' + (current ? current.name : '') + '" and all its logged data? This can\u2019t be undone.')) return;
    ['trips','hoursEntries','jobs','settings','activeGpsTrip'].forEach(base=> rawDelete(pKey(base)));
    profiles = profiles.filter(p=>p.id !== activeProfileId);
    rawSet('app:profiles', JSON.stringify(profiles));
    renderProfileSelect();
    await switchProfile(profiles[0].id);
  });

  async function loadAll(){
    try{
      const raw = rawGet(pKey('trips'));
      trips = raw ? JSON.parse(raw) : [];
    }catch(e){ trips = []; }
    try{
      const raw = rawGet(pKey('hoursEntries'));
      hoursEntries = raw ? JSON.parse(raw) : [];
    }catch(e){ hoursEntries = []; }
    try{
      const raw = rawGet(pKey('jobs'));
      jobs = raw ? JSON.parse(raw) : [];
    }catch(e){ jobs = []; }
    try{
      const raw = rawGet(pKey('settings'));
      const s = raw ? JSON.parse(raw) : {};
      contractedHours = typeof s.contractedHours === 'number' ? s.contractedHours : 160;
      weeklyHours = typeof s.weeklyHours === 'number' ? s.weeklyHours : 40;
      reporterName = typeof s.reporterName === 'string' ? s.reporterName : '';
    }catch(e){ contractedHours = 160; weeklyHours = 40; reporterName = ''; }
    $('contractedHours').value = contractedHours;
    $('weeklyHours').value = weeklyHours;
    $('reporterName').value = reporterName;
    $('fromLoc').value = '';
    try{
      const raw = rawGet(pKey('activeGpsTrip'));
      if(raw){
        const data = JSON.parse(raw);
        if(data && data.coord){
          gpsStartCoord = data.coord;
          gpsStartTime = data.time;
          gpsFromAddr = data.addr || '';
          fromCoord = data.coord;
          $('fromLoc').value = gpsFromAddr;
        }
      }
    }catch(e){}
    renderProfileSelect();
    autoSuggestWorkForDate();
    renderAll();
  }
  async function saveTrips(){ rawSet(pKey('trips'), JSON.stringify(trips)); }
  async function saveHours(){ rawSet(pKey('hoursEntries'), JSON.stringify(hoursEntries)); }
  async function saveJobs(){ rawSet(pKey('jobs'), JSON.stringify(jobs)); }
  async function saveSettings(){ rawSet(pKey('settings'), JSON.stringify({contractedHours, weeklyHours, reporterName})); }

  // ---------------- Job helpers ----------------
  function jobsForDate(dateStr){
    return jobs.filter(j => j.startDate <= dateStr && dateStr <= j.endDate);
  }
  function actualHoursForDate(dateStr){
    return hoursEntries.filter(h => h.date === dateStr).reduce((a,h)=>a+h.hours,0);
  }
  function dayOverExpected(dateStr){
    const dj = jobsForDate(dateStr);
    if(dj.length === 0) return false;
    const expected = dj[0].expectedHours || 0;
    if(expected <= 0) return false;
    return actualHoursForDate(dateStr) > expected;
  }
  function jobDaysCount(job){
    const s = new Date(job.startDate+'T00:00:00');
    const e = new Date(job.endDate+'T00:00:00');
    return Math.round((e - s) / 86400000) + 1;
  }
  function refreshHoursJobSelect(){
    const sel = $('hoursJob');
    const current = sel.value;
    const sorted = jobs.slice().sort((a,b)=> b.startDate.localeCompare(a.startDate));
    sel.innerHTML = '<option value="">No job / general hours</option>' + sorted.map(j=>
      '<option value="' + j.id + '">' + escapeHtml(j.title) + ' (' + j.startDate + ' to ' + j.endDate + ')</option>'
    ).join('');
    if(sorted.some(j=>String(j.id)===current)) sel.value = current;
  }

