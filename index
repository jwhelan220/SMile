      <div class="gauge-status" id="exportStatus" style="text-align:left;margin-top:10px;"></div>
    </div>

    <div class="card" id="installCard">
      <div class="card-head">Install on your phone</div>
      <button class="btn-secondary" id="installBtn" style="width:100%;">Add to Home Screen</button>
      <div class="gauge-status" id="installStatus" style="text-align:left;margin-top:10px;"></div>
    </div>

  </div>

  <!-- ============ CALENDAR ============ -->
  <div class="view" id="view-calendar">
    <div class="card">
      <div class="mode-tabs">
        <div class="cal-view-tab active" data-calview="month">Month</div>
        <div class="cal-view-tab" data-calview="year">Year</div>
      </div>

      <div id="calMonthView">
        <div class="cal-head">
          <button class="cal-nav-btn" id="calPrev">&#8249;</button>
          <div class="cal-month-label" id="calMonthLabel">Month Year</div>
          <button class="cal-nav-btn" id="calNext">&#8250;</button>
        </div>
        <div class="cal-grid" id="calDow"></div>
        <div class="cal-grid" id="calGrid" style="margin-top:5px;"></div>
        <div class="cal-legend">
          <span><span class="sw away"></span>Away on a job</span>
          <span><span class="sw over"></span>Worked over expected hours</span>
          <span><span class="dot work"></span>Work trip</span>
          <span><span class="dot personal"></span>Personal trip</span>
        </div>
      </div>

      <div id="calYearView" class="hidden">
        <div class="cal-head">
          <button class="cal-nav-btn" id="yearPrev">&#8249;</button>
          <div class="cal-month-label" id="calYearLabel">Year</div>
          <button class="cal-nav-btn" id="yearNext">&#8250;</button>
        </div>
        <div id="yearGrid"></div>
        <div class="cal-legend">
          <span><span class="dot work"></span>Work miles</span>
          <span><span class="dot personal"></span>Personal miles</span>
          <span><span class="dot hours"></span>Hours worked</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ============ JOBS ============ -->
  <div class="view" id="view-jobs">
    <div class="card">
      <div class="card-head">Log a job</div>
      <div class="hint" style="margin-top:-4px;">A job is a shift or event that takes you away from home. Give it a date range and a general expected working time, then log your actual hours as you go &mdash; the calendar will flag any day you went over.</div>

      <div class="field">
        <label for="jobTitle">Job / event title</label>
        <input type="text" id="jobTitle" placeholder="e.g. Co-op Live deployment">
      </div>
      <div class="field">
        <label for="jobLocation">Location</label>
        <input type="text" id="jobLocation" placeholder="e.g. Manchester">
      </div>
      <div class="row-2">
        <div class="field">
          <label for="jobStart">Away from</label>
          <input type="date" id="jobStart">
        </div>
        <div class="field">
          <label for="jobEnd">Away until</label>
          <input type="date" id="jobEnd">
        </div>
      </div>
      <div class="field">
        <label for="jobExpectedHours">Expected working hours per day</label>
        <input type="number" id="jobExpectedHours" placeholder="e.g. 10" min="0" step="0.5">
      </div>
      <div class="field">
        <label for="jobNotes">Notes</label>
        <textarea id="jobNotes" placeholder="Optional details"></textarea>
      </div>
      <button class="btn-primary" id="addJobBtn">Save job</button>
      <button class="btn-secondary hidden" id="cancelJobEditBtn" style="width:100%;margin-top:10px;">Cancel edit</button>
    </div>

    <div class="card">
      <div class="card-head">Jobs</div>
      <div id="jobsList"></div>
    </div>
  </div>

  <!-- ============ LOG TRIP ============ -->
  <div class="view" id="view-trip">
    <div class="card">
      <div class="card-head">Distance calculator</div>

      <div class="mode-tabs">
        <div class="mode-tab active" data-mode="odometer">Odometer</div>
        <div class="mode-tab" data-mode="manual">Manual</div>
        <div class="mode-tab" data-mode="address">From &rarr; To</div>
        <div class="mode-tab" data-mode="gps">GPS trip</div>
      </div>

      <div class="chip-row hidden" id="recentAddressChips"></div>

      <div class="field">
        <label for="tripDate">Date</label>
        <input type="date" id="tripDate">
      </div>

      <div class="row-2">
        <div class="field autocomplete-field">
          <label for="fromLoc">From</label>
          <div class="ac-wrap">
            <input type="text" id="fromLoc" autocomplete="off" placeholder="e.g. Depot, Manchester">
            <div class="ac-suggestions" id="fromSuggestions"></div>
          </div>
        </div>
        <div class="field autocomplete-field">
          <label for="toLoc">To</label>
          <div class="ac-wrap">
            <input type="text" id="toLoc" autocomplete="off" placeholder="e.g. NEC Birmingham">
            <div class="ac-suggestions" id="toSuggestions"></div>
          </div>
        </div>
      </div>

      <div id="odometerInputs">
        <div class="row-2">
          <div class="field">
            <label for="startOdo">Start odometer (mi)</label>
            <input type="number" id="startOdo" placeholder="e.g. 48210" min="0" step="0.1">
          </div>
          <div class="field">
            <label for="endOdo">End odometer (mi)</label>
            <input type="number" id="endOdo" placeholder="e.g. 48267" min="0" step="0.1">
          </div>
        </div>
      </div>

      <div id="manualInput" class="hidden">
        <div class="field">
          <label for="manualDistance">Distance travelled (mi)</label>
          <input type="number" id="manualDistance" placeholder="e.g. 57" min="0" step="0.1">
        </div>
      </div>

      <div id="addressInput" class="hidden">
        <div class="hint">Type at least 3 letters of an address to get suggestions, pick one for From and To, then calculate. Uses OpenStreetMap &mdash; it's a route estimate, so use odometer readings for exact mileage claims.</div>
        <div class="field">
          <label for="arrivalTime">Need to arrive on site by (optional)</label>
          <input type="time" id="arrivalTime">
        </div>
        <button class="btn-secondary" id="calcRouteBtn" style="width:100%;margin-bottom:14px;">Calculate route</button>
        <div class="route-info hidden" id="routeInfo">
          <div class="route-info-row"><span>Estimated drive time</span><strong id="routeDuration">&mdash;</strong></div>
          <div class="route-info-row" id="leaveByRow" style="display:none;"><span>Leave by</span><strong id="leaveByTime">&mdash;</strong></div>
        </div>
      </div>

      <div id="gpsInput" class="hidden">
        <div class="hint">Tap Start when you set off &mdash; it captures your location as the From address. Tap End when you arrive to fill in the To address and calculate the driving distance automatically.</div>
        <div class="gps-status" id="gpsStatusBox">
          <span id="gpsStatusText"></span>
          <button class="gps-cancel" id="cancelGpsBtn">Cancel this trip</button>
        </div>
        <button class="btn-secondary" id="startGpsBtn" style="width:100%;">Start trip</button>
        <button class="btn-primary teal hidden" id="endGpsBtn" style="width:100%;margin-top:0;">End trip</button>
